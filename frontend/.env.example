# Frontend — copy to .env.local for local dev

# --- Vercel (production build) — set in Vercel Project → Settings → Environment Variables ---
# Required for deployed site to call your API:
# VITE_BACKEND_URL=https://your-service.onrender.com/api

# --- Local dev ---
# http://localhost:5000/api works with CORS; /api proxy is also used when URL is https remote or omitted.
VITE_BACKEND_URL=http://localhost:5000/api

# Force remote API while running `vite dev` (optional)
# VITE_USE_REMOTE_API=true
