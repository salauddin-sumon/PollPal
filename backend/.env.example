# Backend — copy to .env and fill in values

# MongoDB (Atlas connection string)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT signing secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random

# Local dev
PORT=5000
NODE_ENV=development

# CORS: browser origin of your frontend (comma-separated for production + Vercel previews)
FRONTEND_URL=http://localhost:5173

# Optional extra allowed origins (comma-separated), e.g. a second Vercel preview URL
# CORS_EXTRA_ORIGINS=

# --- Render (production) ---
# NODE_ENV=production
# PORT is injected by Render — do not set manually unless needed
# FRONTEND_URL=https://your-app.vercel.app,https://your-app-git-main-xxx.vercel.app
# (match the exact URLs Vercel shows; add preview URLs if you test PR deployments)
